# ============================================
# VELOCE — Environment Variables
# ============================================

# PostgreSQL via Neon (neon.tech — free tier)
# Create project → copy "Connection string"
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/veloce?sslmode=require"

# NextAuth.js secret (run: openssl rand -base64 32)
AUTH_SECRET="replace-with-32-char-random-string"
NEXTAUTH_URL="http://localhost:3000"

# Upstash Redis (upstash.com → Create Database → REST API)
UPSTASH_REDIS_REST_URL="https://your-db.upstash.io"
UPSTASH_REDIS_REST_TOKEN="AXxx..."

# Anthropic API key (console.anthropic.com)
ANTHROPIC_API_KEY="sk-ant-api03-..."

# Webhook HMAC secret (run: openssl rand -hex 32)
WEBHOOK_SECRET="replace-with-random-hex-string"
